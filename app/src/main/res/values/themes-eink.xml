<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:android="http://schemas.android.com/apk/res/android">
    <style name="KeyboardTheme.EInk">
        <item name="inputViewStyle">@style/InputView</item>
        <item name="keyboardStyle">@style/Keyboard.EInk</item>
        <item name="keyboardViewStyle">@style/KeyboardView.EInk</item>
        <item name="mainKeyboardViewStyle">@style/MainKeyboardView.EInk</item>
        <item name="moreKeysKeyboardStyle">@style/MoreKeysKeyboard.EInk</item>
        <item name="moreKeysKeyboardViewStyle">@style/MoreKeysKeyboardView.EInk</item>
        <item name="functionalTextColor">@color/key_functional_text_color_eink</item>
        <item name="popupPanelBackgroundColor">@color/background_eink</item>
        <item name="keyPressedBackgroundColor">@color/key_background_pressed_eink</item>
        <item name="keyNormalBackgroundColor">@color/key_background_normal_eink</item>
    </style>
    <style
        name="Keyboard.EInk"
        parent="Keyboard">
        <item name="keyboardBottomPadding">3.5%p</item>
    </style>
    <style
        name="MoreKeysKeyboard.EInk"
        parent="Keyboard.EInk">
        <item name="keyboardTopPadding">0%p</item>
        <item name="keyboardBottomPadding">0%p</item>
        <item name="horizontalGap">0%p</item>
    </style>
    <style
        name="MoreKeysKeyboardView.EInk"
        parent="KeyboardView.EInk">
        <item name="android:background">@color/background_eink</item>
        <item name="keyBackground">@drawable/btn_keyboard_key_eink</item>
        <item name="keyTypeface">normal</item>
        <item name="verticalCorrection">@dimen/config_more_keys_keyboard_vertical_correction</item>
    </style>
    <style
        name="KeyboardView.EInk"
        parent="KeyboardView">
        <item name="android:background">@color/background_eink</item>
        <item name="keyBackground">@drawable/btn_keyboard_key_eink</item>
        <item name="functionalKeyBackground">@drawable/btn_keyboard_key_eink</item>
        <item name="spacebarBackground">@drawable/btn_keyboard_key_eink</item>
        <item name="keyTextColor">@color/key_text_color_eink</item>
        <item name="keyTextInactivatedColor">@color/key_text_inactive_color_eink</item>
        <item name="keyHintLetterColor">@color/key_hint_letter_color_eink</item>
        <item name="keyHintLabelColor">@color/key_text_inactive_color_eink</item>
        <item name="keyShiftedLetterHintInactivatedColor">@color/key_text_inactive_color_eink</item>
        <item name="keyShiftedLetterHintActivatedColor">@color/key_text_color_eink</item>
        <item name="keyPreviewTextColor">@color/key_text_color_eink</item>
        <item name="languageOnSpacebarTextColor">@color/key_text_inactive_color_eink</item>
    </style>
    <style
        name="MainKeyboardView.EInk"
        parent="KeyboardView.EInk">
        <item name="keyPreviewBackground">@drawable/keyboard_key_feedback_background</item>
        <item name="keyPreviewHeight">0dp</item>
        <item name="keyPreviewWidth">0dp</item>
        <item name="keyPreviewOffset">0dp</item>
    </style>
</resources>
