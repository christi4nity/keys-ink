<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android">

    <SwitchPreference
        android:key="pref_voice_input_enabled"
        android:title="@string/voice_input_enabled"
        android:summary="@string/voice_input_enabled_summary"
        android:defaultValue="true" />

    <Preference
        android:key="voice_permission_status"
        android:title="@string/voice_pref_mic_permission_title"
        android:summary="@string/voice_pref_mic_permission_not_granted"
        android:dependency="pref_voice_input_enabled" />

    <Preference
        android:key="voice_model_status"
        android:title="@string/voice_pref_model_title"
        android:summary="@string/voice_pref_model_not_downloaded"
        android:dependency="pref_voice_input_enabled" />

</PreferenceScreen>
