<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <switch>
        <case latin:voiceInputKeyEnabled="true">
            <Key
                latin:keyStyle="micKeyStyle"
                latin:keyWidth="10%p" />
        </case>
        <!-- voiceInputKeyEnabled="false": no mic key -->
    </switch>
</merge>
